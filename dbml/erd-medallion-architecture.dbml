// -- ##############################################################################
// -- ##  ETL FLOW — Bagaimana data mengalir antar layer
// -- ##############################################################################
// --
// -- BRONZE → SILVER (per source):
// --   bronze_spotify_raw → parse JSON → silver_spotify_artist
// --                                     → silver_spotify_album
// --                                     → silver_spotify_album_artist
// --                                     → silver_spotify_track (+ ISRC!)
// --                                     → silver_spotify_track_artist
// --
// --   bronze_youtube_raw  → parse JSON → silver_youtube_channel
// --                                     → silver_youtube_video
// --
// -- SILVER → GOLD (cross-source + agregasi):
// --   1. silver_spotify_track + silver_youtube_video
// --      → silver_song_mapping  (matching by normalized title + artist name)
// --      → gold_dim_song         (song kanonikal, dengan aggregate counts)
// --
// --   2. silver_spotify_artist + silver_youtube_channel
// --      → gold_dim_artist       (unified artist profile)
// --
// --   3. silver_spotify_album
// --      → gold_dim_album        (album profile + aggregate)
// --
// --   4. silver_ingestion_log + silver_data_quality_log
// --      → gold_fact_ingestion_summary  (harian monitoring)
// --
// --   5. gold_dim_song (daily snapshot)
// --      → gold_fact_song_daily_snapshot  (time-series history, optional)
